{
  "manifest_version": 3,
  "name": "RGAA Audit",
  "version": "0.2.1",
  "description": "Pré-audit accessibilité RGAA 4.1 — Le Singe Du Numérique",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "panel/panel.html",
    "default_title": "RGAA Audit — Le Singe Du Numérique",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
